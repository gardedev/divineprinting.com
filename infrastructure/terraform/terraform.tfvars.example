# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git

aws_region              = "us-east-1"
environment             = "prod"
snipcart_secret_api_key = "YOUR_SNIPCART_SECRET_API_KEY"
ses_sender_email        = "noreply@divineprinting.com"
magic_link_base_url     = "https://www.divineprinting.com"
magic_link_secret       = "GENERATE_A_RANDOM_64_CHAR_HEX_STRING"
